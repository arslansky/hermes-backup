#!/usr/bin/env python3
"""Ming Pao daily scraper — with proxy auth, scrapes all sections for a given date"""

# ===== KNOWN ISSUES (2026-06-09) =====
# - Section pages need JS rendering (CloakBrowser) to get article links
# - Article content works with requests + proxy
# - 要聞版需登入才能顯示完整文章 — 已修：CloakBrowser + proxy + cookie accept
# ====================================
import requests, json, re, sys
from urllib.parse import urljoin, unquote
from datetime import datetime
from concurrent.futures import ThreadPoolExecutor, as_completed
from bs4 import BeautifulSoup

# ===== NO PROXY NEEDED =====
# - Section pages: CloakBrowser bypasses Cloudflare directly (no proxy needed)
# - Article pages: news.mingpao.com article pages have NO Cloudflare block — requests.get() works fine without proxy
# Proxy was removed2026-06-10 after testing confirmed CF blocks requests.get() regardless of proxy.

HEADERS = {
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36'
}

BASE = "https://news.mingpao.com"

SECTIONS = [
    ("要聞", "https://news.mingpao.com/pns/要聞/section/latest/s00001"),
    ("港聞", "https://news.mingpao.com/pns/港聞/section/latest/s00002"),
    ("經濟", "https://news.mingpao.com/pns/經濟/section/latest/s00004"),
    ("娛樂", "https://news.mingpao.com/pns/娛樂/section/latest/s00016"),
    ("副刊", "https://news.mingpao.com/pns/副刊/section/latest/s00005"),
    ("社評", "https://news.mingpao.com/pns/社評/section/latest/s00003"),
    ("觀點", "https://news.mingpao.com/pns/觀點/section/latest/s00012"),
    ("中國", "https://news.mingpao.com/pns/中國/section/latest/s00013"),
    ("國際", "https://news.mingpao.com/pns/國際/section/latest/s00014"),
    ("即時港聞", "https://news.mingpao.com/ins/港聞/section/latest/s00001"),
    ("即時熱點", "https://news.mingpao.com/ins/熱點/section/latest/s00024"),
    ("即時兩岸", "https://news.mingpao.com/ins/兩岸/section/latest/s00004"),
    ("即時國際", "https://news.mingpao.com/ins/國際/section/latest/s00005"),
]

def fetch_section(name, url, date_str):
    """Fetch article links from a section page using CloakBrowser (JS rendering).

    NOTE: CloakBrowser bypasses Cloudflare on its own — NO proxy needed.
    NOTE: This function must be called SEQUENTIALLY (not in ThreadPoolExecutor).
 CloakBrowser's Playwright Sync API conflicts with asyncio in threads.
    """
    try:
        from cloakbrowser import launch
        import time
        browser = launch(
            headless=True
            # NO proxy — CloakBrowser is a stealth browser that bypasses CF directly
        )
        page = browser.new_page()
        page.goto(url, timeout=45000, wait_until='domcontentloaded')
        time.sleep(2)

        # Dismiss cookie consent banner if present
        try:
            accept_btn = page.locator('text="接受"').first
            if accept_btn.is_visible():
                accept_btn.click()
                time.sleep(1)
        except Exception:
            pass  # No cookie banner — continue

        html = page.content()
        browser.close()

        # Extract article links — CloakBrowser returns JS-rendered HTML with absolute URLs
        links_rel = re.findall(r'href=\"(\.\./(?:ins|pns)/[^"]*?article[^"]+)\"', html)
        links_abs = re.findall(r'href=\"(https://news\.mingpao\.com/(?:ins|pns)/[^"]*?article[^"]+)\"', html)
        all_links = links_rel + links_abs

        abs_links = []
        for l in all_links:
            if l.startswith('https://'):
                abs_url = l
            else:
                abs_url = urljoin(BASE, l.lstrip('../'))
            # Extract title from URL slug (last path segment, minus timestamp suffix)
            slug = abs_url.split('/')[-1]
            title_from_slug = unquote(re.sub(r'-[^-]+$', '', slug)).replace('-', '，')
            abs_links.append((abs_url, title_from_slug, name))
        return name, abs_links, 200
    except Exception as e:
        print(f"  [WARN] Section '{name}' failed: {e}", file=sys.stderr)
        return name, [], None

def scrape_article(url, fallback_title, section_name):
    try:
        r = requests.get(url, headers=HEADERS, timeout=20)
        r.encoding = 'utf-8'
        soup = BeautifulSoup(r.text, 'html.parser')

        h1 = soup.find('h1')
        title = h1.get_text(strip=True) if h1 else fallback_title

        og = soup.find('meta', property='og:description')
        summary = og.get('content', '') if og else ''

        paras = []
        for p in soup.find_all('p'):
            t = p.get_text(strip=True)
            if len(t) > 20 and 'outdated browser' not in t.lower():
                paras.append(t)
        body = '\n'.join(paras[:30]) if paras else summary

        return {'url': url, 'title': title, 'section': section_name, 'body': body[:500], 'summary': summary[:300]}
    except Exception as e:
        return {'url': url, 'title': fallback_title, 'section': section_name, 'body': '', 'summary': '', 'error': str(e)[:100]}

def main():
    date_str = sys.argv[1] if len(sys.argv) > 1 else datetime.now().strftime('%Y%m%d')
    output_file = f"/tmp/mingpao_{date_str}.json"

    print(f"=== Ming Pao Scraper | Date: {date_str} | Proxy: none (CloakBrowser bypasses CF) ===", file=sys.stderr)

    # Phase 1: Fetch section pages — CloakBrowser MUST run sequentially
    # (Playwright Sync API conflicts with asyncio/ThreadPoolExecutor)
    print("Phase 1: Fetching section pages (sequential CloakBrowser)...", file=sys.stderr)
    section_articles = {}
    for n, u in SECTIONS:
        name, articles, status = fetch_section(n, u, date_str)
        section_articles[name] = (articles, status)
        print(f"  {name}: {len(articles)} articles [status={status}]", file=sys.stderr)

    # Retry failed sections once
    failed_sections = [n for n, (arts, st) in section_articles.items() if st is None or len(arts) == 0]
    if failed_sections:
        print(f"Phase 1b: Retrying {len(failed_sections)} failed sections...", file=sys.stderr)
        for n in failed_sections:
            u = next(u for name, u in SECTIONS if name == n)
            name, articles, status = fetch_section(n, u, date_str)
            section_articles[name] = (articles, status)
            ok = len(articles)
            print(f"  Retry {name}: {ok} articles [status={status}]", file=sys.stderr)

    # Collect all unique article URLs
    all_urls = {}
    for sec, (articles, status) in section_articles.items():
        for url, title, sec_name in articles:
            if url not in all_urls:
                all_urls[url] = (sec_name, title)

    total = len(all_urls)
    print(f"  Found {total} unique articles across {len(SECTIONS)} sections", file=sys.stderr)
    for sec, (articles, status) in section_articles.items():
        print(f"    {sec}: {len(articles)} articles [status={status}]", file=sys.stderr)

    # Phase 2: Scrape article content
    print("Phase 2: Scraping article content...", file=sys.stderr)
    results = []
    urls_list = list(all_urls.items())
    batch_size = 80

    for i in range(0, len(urls_list), batch_size):
        batch = urls_list[i:i+batch_size]
        batch_results = []
        with ThreadPoolExecutor(max_workers=10) as executor:
            futures = {executor.submit(scrape_article, url, title, sec): (sec, url)
                       for url, (sec, title) in batch}
            for f in as_completed(futures):
                result = f.result()
                batch_results.append(result)

        results.extend(batch_results)
        print(f"  Batch {i//batch_size + 1}: scraped {len(batch_results)} articles (total: {len(results)})", file=sys.stderr)

    # Phase 2b: Retry failed articles (proxy is reliable — retry usually succeeds)
    failed = [r for r in results if r.get('error')]
    if failed:
        print(f"Phase 2b: Retrying {len(failed)} failed articles...", file=sys.stderr)
        retry_results = []
        with ThreadPoolExecutor(max_workers=10) as executor:
            futures = {executor.submit(scrape_article, r['url'], r['title'], r['section']): r['url']
                       for r in failed}
            for f in as_completed(futures):
                retry_results.append(f.result())
        # Merge retry results back
        failed_urls = {r['url'] for r in failed}
        merged = [r for r in results if r['url'] not in failed_urls]
        merged.extend(retry_results)
        results = merged
        ok = sum(1 for r in retry_results if not r.get('error'))
        print(f"  Retry: {ok}/{len(failed)} recovered", file=sys.stderr)

    # Save results
    output = {
        'date': date_str,
        'scraped_at': datetime.now().isoformat(),
        'total_articles': len(results),
        'sections': {s: len([r for r in results if r['section'] == s]) for s in dict.fromkeys(r['section'] for r in results)},
        'articles': results
    }

    with open(output_file, 'w', encoding='utf-8') as f:
        json.dump(output, f, ensure_ascii=False, indent=2)

    print(f"\n✅ Done! {len(results)} articles saved to {output_file}", file=sys.stderr)
    print(f"   Sections: {output['sections']}", file=sys.stderr)
    return output

if __name__ == "__main__":
    main()